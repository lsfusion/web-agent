<?xml version="1.0" encoding="utf-8"?>
<!-- MSIX manifest for the jpackage app-image; ${VERSION} is a 4-part version
     substituted by scripts/package-msix.ps1. Publisher must match the code
     signing certificate subject exactly, or the signed package won't install. -->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap rescap">

    <Identity
        Name="com.lsfusion.webagent"
        Publisher="CN=Aliaksei Kirkouski, O=Aliaksei Kirkouski, L=Warsaw, S=Masovian Voivodeship, C=PL"
        Version="${VERSION}"
        ProcessorArchitecture="x64" />

    <Properties>
        <DisplayName>lsFusion Web Agent</DisplayName>
        <PublisherDisplayName>lsFusion</PublisherDisplayName>
        <Logo>Assets\StoreLogo.png</Logo>
    </Properties>

    <Resources>
        <Resource Language="en-us" />
    </Resources>

    <Dependencies>
        <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0" />
    </Dependencies>

    <Capabilities>
        <Capability Name="internetClient" />
        <rescap:Capability Name="runFullTrust" />
    </Capabilities>

    <Applications>
        <Application Id="WebAgent" Executable="web-agent.exe" EntryPoint="Windows.FullTrustApplication">
            <uap:VisualElements
                DisplayName="lsFusion Web Agent"
                Description="Local helper service for the lsFusion web client: print, file ops, sockets, COM ports."
                BackgroundColor="transparent"
                Square150x150Logo="Assets\Square150x150Logo.png"
                Square44x44Logo="Assets\Square44x44Logo.png" />
        </Application>
    </Applications>
</Package>
